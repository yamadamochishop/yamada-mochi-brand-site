# Preview / current Vercel aliases
NEXT_PUBLIC_SITE_URL=https://yamada-mochi-brand-site.vercel.app
NEXT_PUBLIC_SITE_INDEXABLE=false

# Set only after www.yamadamochi.com is connected, HTTPS is valid, and the
# production deployment is confirmed. Redeploy after changing these values.
# NEXT_PUBLIC_SITE_URL=https://www.yamadamochi.com
# NEXT_PUBLIC_SITE_INDEXABLE=true

# Leave blank until the fixed six-flavour gift product exists in BASE.
NEXT_PUBLIC_BASE_GIFT_URL=
NEXT_PUBLIC_BASE_URL=https://yamadamochi.thebase.in
NEXT_PUBLIC_CONTACT_EMAIL=info@yamadamochi.com
NEXT_PUBLIC_GOOGLE_FORM_URL=
# Google Analytics 4 (production measurement ID)
NEXT_PUBLIC_GA_ID=G-G4QWYR6EH4

# 将来Sanity CMSを使う場合に設定します。初期公開では空でOKです。
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
